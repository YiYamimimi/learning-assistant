{
  "manifest_version": 3,
  "name": "My Extension",
  "version": "1.0.0",
  "description": "A Chrome extension built with React and Vite",
  "permissions": [
    "sidePanel",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "https://*/*"
  ],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "打开侧边栏"
  }
}
